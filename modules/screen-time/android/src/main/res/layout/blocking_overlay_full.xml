<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:padding="24dp">

    <!-- Section 01: BRAIN_ROT_MONITOR -->
    <LinearLayout
        android:id="@+id/rotContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/rotMascot"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/stage_1"
            android:scaleType="centerInside" />

        <TextView
            android:id="@+id/rotStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.1"
            android:text="Your Brain is at 78% Rot"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/protocolLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.2"
        android:text="REMAINING RESTRICTION PERIOD"
        android:textColor="#44FFFFFF"
        android:textSize="9sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rotContainer" />

    <TextView
        android:id="@+id/timerText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="-0.02"
        android:text="04:37"
        android:textColor="#FFFFFF"
        android:textSize="64sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/protocolLabel" />

    <!-- Section 02: COACH_MESSAGE_HUB -->
    <FrameLayout
        android:id="@+id/messageCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:background="#0A0A0A"
        app:layout_constraintTop_toBottomOf="@id/timerText">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="28dp">

            <TextView
                android:id="@+id/messageText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:lineSpacingExtra="4dp"
                android:text="You chose to protect your focus today."
                android:textAlignment="center"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/coachSubText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="sans-serif-medium"
                android:lineHeight="18dp"
                android:text="Your brain is already starting to feel clearer ❤️🩹"
                android:textAlignment="center"
                android:textColor="#88FFFFFF"
                android:textSize="12sp" />

        </LinearLayout>
    </FrameLayout>

    <!-- Section 03: POSITIVE_ACTION_STACK -->
    <LinearLayout
        android:id="@+id/actionStack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/goHomeButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:backgroundTint="#FFFFFF"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.1"
            android:text="I'M GOOD — KEEP GOING"
            android:textColor="#000000" />

        <Button
            android:id="@+id/takeBreakButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="#131313"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.05"
            android:text="TAKE A  BREAK"
            android:textColor="#FFFFFF" />

      
    </LinearLayout>

    <TextView
        android:id="@+id/brandingText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.3"
        android:text="UNLINK • FOCUS COACH"
        android:textColor="#22FFFFFF"
        android:textSize="8sp"
        app:layout_constraintBottom_toTopOf="@id/actionStack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
