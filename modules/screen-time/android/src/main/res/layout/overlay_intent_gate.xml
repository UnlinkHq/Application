<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/intent_gate_bg"
    android:padding="32dp">

    <!-- Header Section -->
    <TextView
        android:id="@+id/gateProtocolLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.4"
        android:text="PROTOCOL_V2_ACTIVE"
        android:textColor="#22FFFFFF"
        android:textSize="10sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Emotional Hook: Brain Status -->
    <LinearLayout
        android:id="@+id/brainStatusContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:background="@drawable/brain_status_pill"
        app:layout_constraintTop_toBottomOf="@id/gateProtocolLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        
        <TextView
            android:id="@+id/brainStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:text="🧠 12% FRESH BRAIN"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:letterSpacing="0.05" />
    </LinearLayout>

    <TextView
        android:id="@+id/greetingText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:fontFamily="sans-serif-light"
        android:text="Hey there, quick breath."
        android:textColor="#99FFFFFF"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/brainStatusContainer" />

    <TextView
        android:id="@+id/intentQuestion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="sans-serif-black"
        android:textAlignment="center"
        android:text="Why are you opening\nthis app today?"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:lineSpacingExtra="4dp"
        app:layout_constraintTop_toBottomOf="@id/greetingText" />

    <!-- Positive Reinforcement: Win Line -->
    <TextView
        android:id="@+id/winLineText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="sans-serif-medium"
        android:textAlignment="center"
        android:text="You've already won back 47 minutes this week 🔥\nYour brain thanks you."
        android:textColor="#66FFFFFF"
        android:textSize="11sp"
        android:lineSpacingExtra="2dp"
        app:layout_constraintTop_toBottomOf="@id/intentQuestion" />

    <!-- Countdown / Calm State -->
    <LinearLayout
        android:id="@+id/calmContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/winLineText">

        <TextView
            android:id="@+id/calmTimerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:text="3"
            android:textColor="#FFFFFF"
            android:textSize="48sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-thin"
            android:letterSpacing="0.1"
            android:text="CALIBRATING_FOCUS..."
            android:textColor="#44FFFFFF"
            android:textSize="9sp" />
    </LinearLayout>

    <!-- Action Buttons (Hidden during calm phase) -->
    <LinearLayout
        android:id="@+id/actionContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/dmOnlyButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/intent_button_primary"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.1"
            android:text="1. DM CONNECT ONLY"
            android:textColor="#000000"
            android:textAllCaps="true"
            android:textSize="12sp" />

        <Button
            android:id="@+id/longVideosButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/intent_button_secondary"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.1"
            android:text="2. LONG VIDEOS ONLY"
            android:textColor="#FFFFFF"
            android:textAllCaps="true"
            android:textSize="12sp" />

        <Button
            android:id="@+id/reelsLimitButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/intent_button_secondary"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.1"
            android:text="3. 5 REELS MAX"
            android:textColor="#FFFFFF"
            android:textAllCaps="true"
            android:textSize="12sp" />

        <Button
            android:id="@+id/fullFocusButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/intent_button_secondary"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.1"
            android:text="4. FULL FOCUS MODE"
            android:textColor="#FFFFFF"
            android:textAllCaps="true"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/cancelButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center"
            android:fontFamily="sans-serif-medium"
            android:text="Actually, nevermind."
            android:textColor="#66FFFFFF"
            android:textSize="13sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
